# ── Database (Supabase PostgreSQL) ────────────────────────────────────────────
# Find these in Supabase → Project Settings → Database → Connection string
ConnectionStrings__DefaultConnection="Host=YOUR_HOST.supabase.com;Database=postgres;Username=postgres.YOUR_PROJECT_REF;Password=YOUR_PASSWORD;SSL Mode=Require;Trust Server Certificate=true"

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate a strong random secret: openssl rand -base64 32
Jwt__Secret="REPLACE_WITH_RANDOM_SECRET_MIN_32_CHARS"
Jwt__Issuer="MiniStack"
Jwt__Audience="MiniStackApp"
Jwt__AccessTokenExpiryMinutes="15"
Jwt__RefreshTokenExpiryDays="30"

# ── Apple Sign In ─────────────────────────────────────────────────────────────
# Must match the bundle identifier in app.config.js / App Store Connect
Apple__BundleId="com.yourcompany.ministack"

# ── Email (password reset) ────────────────────────────────────────────────────
# Any SMTP provider works: SendGrid, Postmark, Mailgun, Gmail, etc.
# Leave SmtpHost empty in development — the reset link will be logged to console.
Email__SmtpHost="smtp.sendgrid.net"
Email__SmtpPort="587"
Email__FromAddress="noreply@ministack.app"
Email__Username="apikey"
Email__Password="YOUR_SENDGRID_API_KEY"

# ── Google OAuth (client IDs are not secrets — client secret is unused here) ──
# These are already in appsettings.json; only override here if you need different
# IDs per environment.
# Google__AllowedClientIds__0="YOUR_ANDROID_CLIENT_ID.apps.googleusercontent.com"
# Google__AllowedClientIds__1="YOUR_IOS_CLIENT_ID.apps.googleusercontent.com"
# Google__AllowedClientIds__2="YOUR_WEB_CLIENT_ID.apps.googleusercontent.com"
