# ── API ───────────────────────────────────────────────────────────────────────
# Local dev: http://YOUR_LAN_IP:5001  (find with `ipconfig` / `ifconfig`)
# Production: https://your-app.azurewebsites.net
EXPO_PUBLIC_API_BASE_URL=http://192.168.0.143:5001

# ── Google OAuth ──────────────────────────────────────────────────────────────
# From Google Cloud Console → APIs & Services → Credentials
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=YOUR_ANDROID_CLIENT_ID.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=YOUR_IOS_CLIENT_ID.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=YOUR_WEB_CLIENT_ID.apps.googleusercontent.com

# ── Sentry (optional — crash reporting) ──────────────────────────────────────
# Create a project at https://sentry.io → React Native → copy the DSN
EXPO_PUBLIC_SENTRY_DSN=
