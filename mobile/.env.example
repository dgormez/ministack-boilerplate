# ── API ───────────────────────────────────────────────────────────────────────
# Local dev: http://YOUR_LAN_IP:5000  (find with `ipconfig` / `ifconfig`)
# Production: https://your-app.azurewebsites.net
EXPO_PUBLIC_API_BASE_URL=http://192.168.1.100:5000

# ── Sentry (optional — crash reporting) ──────────────────────────────────────
# Create a project at https://sentry.io → React Native → copy the DSN
EXPO_PUBLIC_SENTRY_DSN=
